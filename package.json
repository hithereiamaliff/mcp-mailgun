{
    "name": "mcp-mailgun",
    "version": "1.1.0",
    "description": "A Model Context Protocol (MCP) server for Mailgun, enabling MCP-compatible AI clients to interact with the Mailgun email service.",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "mcp-server": "dist/index.js",
        "mailgun-mcp-server": "dist/index.js"
    },
    "files": [
        "dist/",
        "src/openapi.yaml"
    ],
    "license": "Apache-2.0",
    "author": "hithereiamaliff",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hithereiamaliff/mcp-mailgun.git"
    },
    "bugs": {
        "url": "https://github.com/hithereiamaliff/mcp-mailgun/issues"
    },
    "homepage": "https://github.com/hithereiamaliff/mcp-mailgun#readme",
    "keywords": [
        "mailgun",
        "mcp",
        "model-context-protocol",
        "email",
        "ai"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build:tsc": "tsc",
        "dev:http": "npx tsx src/http-server.ts",
        "start": "node dist/index.js",
        "start:http": "node dist/http-server.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "lint": "eslint .",
        "prepare": "npm run build:tsc"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.17.4",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "firebase-admin": "^12.0.0",
        "js-yaml": "^4.1.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^29.0.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.11.0",
        "eslint": "^10.0.0",
        "jest": "^29.0.0",
        "tsx": "^4.20.5",
        "typescript": "^5.3.3"
    }
}
